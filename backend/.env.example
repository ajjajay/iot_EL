# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example
#
# Copy this file to backend/.env for local development.
#   cp backend/.env.example backend/.env
#
# Then fill in your real values. backend/.env is gitignored — never commit it.
# In production (Render), set these same variables in the Render dashboard
# under: Your Service → Environment → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Firebase Realtime Database URL
# Found in: Firebase Console → your project → Realtime Database → Data tab (URL in browser bar)
# Format:   https://<project-id>-default-rtdb.<region>.firebasedatabase.app
FIREBASE_DATABASE_URL=https://iot-fc8b3-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Service Account credentials (Admin SDK — gives full read/write access)
# How to get:
#   1. Firebase Console → Project settings (gear icon) → Service accounts tab
#   2. Click "Generate new private key" → download the JSON file
#   3. Open the JSON, copy ALL contents, paste as a single line below
#      (Render handles multiline fine; for local dev paste it on one line)
# WARNING: This is a secret. Never commit this value. Use Render's secret env vars.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"iot-fc8b3","private_key_id":"YOUR_KEY_ID","private_key":"-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@iot-fc8b3.iam.gserviceaccount.com","client_id":"YOUR_CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40iot-fc8b3.iam.gserviceaccount.com"}


# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Allowed frontend origins for CORS (comma-separated, no spaces)
# Default already includes the Vercel URL + localhost. Override here if needed.
ALLOWED_ORIGINS=https://aditya-sridhar-git-iot2.vercel.app,http://localhost:5173,http://localhost:3000

# Path to a trained model.tflite inside the container
# Default: models/model.tflite (relative to repo root)
# Only set this if you've trained a model and placed it somewhere custom.
# MODEL_PATH=./models/model.tflite


# ── ALTERNATIVE CREDENTIAL FORMAT ─────────────────────────────────────────────
# If your env var system rejects the JSON (e.g., due to quotes or newlines),
# use the base64-encoded version instead of FIREBASE_SERVICE_ACCOUNT_JSON.
#
# How to generate (Linux/Mac):
#   cat serviceAccountKey.json | base64 -w 0
#
# How to generate (Windows PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
#
# FIREBASE_SERVICE_ACCOUNT_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6...
