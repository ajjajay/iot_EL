{
  "rules": {
    // ── PRODUCTION rules ──────────────────────────────────────────────────────
    // Principle of least privilege:
    //   - ESP32 devices write only to their own subtree (matched by UID)
    //   - Dashboard users read everything; write only to /commands and /users
    //   - No unauthenticated access anywhere

    "devices": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": "auth != null && (auth.uid == $deviceId || auth.token.role == 'admin')",

        "commands": {
          // Dashboard users send relay + enrollment commands; devices read them
          ".read":  "auth != null",
          ".write": "auth != null"
        },

        "config": {
          // Only admins can push remote config changes
          ".write": "auth != null && auth.token.role == 'admin'"
        }
      }
    },

    "readings": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid == $deviceId",
        "$readingId": {
          ".validate": "newData.hasChildren(['temperatureC','humidityPct','ts'])"
        }
      }
    },

    // ── Biometric sign-in log ─────────────────────────────────────────────────
    // Each device appends its own sign-in events.
    // .indexOn ts required for anomaly-check frequency query (order_by_child ts).
    "signins": {
      "$deviceId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        ".indexOn": ["ts"],
        "$signinId": {
          ".validate": "newData.hasChildren(['userId','matchScore','success','ts'])"
        }
      }
    },

    // ── Enrolled users registry ───────────────────────────────────────────────
    // Enrollment is written by the device; dashboard can read and delete.
    "users": {
      ".read":  "auth != null",
      "$userId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['userId','name','deviceId','enrolledAt'])"
      }
    },

    // ── Alerts (both env and biometric) ───────────────────────────────────────
    "alerts": {
      ".read":  "auth != null",
      // Written by device firmware or Cloud Function (admin SDK)
      ".write": "auth != null",
      "$deviceId": {
        "$alertId": {
          ".validate": "newData.hasChildren(['deviceId','alertType','ts'])"
        }
      }
    }
  }
}
