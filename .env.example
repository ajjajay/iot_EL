# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── WiFi ──────────────────────────────────────────────────────────────────────
WIFI_SSID=YourNetworkName
WIFI_PASSWORD=YourWiFiPassword

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase Console → Project settings → General → Web API Key
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Found in Firebase Console → Realtime Database → Data tab (URL in browser)
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase Auth (for secured databases)
FIREBASE_USER_EMAIL=device@yourdomain.com
FIREBASE_USER_PASSWORD=ChangeMe123!

# ── Device Identity ───────────────────────────────────────────────────────────
# Unique ID for each ESP32 — change per device before flashing
DEVICE_ID=esp32_node_01
DEVICE_LOCATION=Lab Room A

# ── Dashboard (frontend) ──────────────────────────────────────────────────────
# These go into frontend/app.js — keep them here for reference
FRONTEND_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FRONTEND_AUTH_DOMAIN=your-project-id.firebaseapp.com
FRONTEND_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FRONTEND_PROJECT_ID=your-project-id
FRONTEND_STORAGE_BUCKET=your-project-id.appspot.com
FRONTEND_MESSAGING_SENDER_ID=123456789012
FRONTEND_APP_ID=1:123456789012:web:abcdefabcdefabcdef

# ── Alert Thresholds (overridable per device via Firebase) ────────────────────
TEMP_WARNING_C=35.0
TEMP_CRITICAL_C=45.0
HUMIDITY_WARNING_PCT=80.0
LIGHT_LOW_THRESHOLD=200
