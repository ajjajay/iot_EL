# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── WiFi ──────────────────────────────────────────────────────────────────────
WIFI_SSID=YourNetworkName
WIFI_PASSWORD=YourWiFiPassword

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase Console → Project settings → General → Web API Key
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Found in Firebase Console → Realtime Database → Data tab (URL in browser)
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Firebase Auth (for secured databases)
FIREBASE_USER_EMAIL=device@yourdomain.com
FIREBASE_USER_PASSWORD=ChangeMe123!

# ── Device Identity ───────────────────────────────────────────────────────────
# Unique ID for each ESP32 — change per device before flashing
DEVICE_ID=esp32_node_01
DEVICE_LOCATION=Lab Room A

# ── Dashboard (frontend) ──────────────────────────────────────────────────────
# These go into frontend/app.js — keep them here for reference
FRONTEND_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FRONTEND_AUTH_DOMAIN=your-project-id.firebaseapp.com
FRONTEND_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
FRONTEND_PROJECT_ID=your-project-id
FRONTEND_STORAGE_BUCKET=your-project-id.appspot.com
FRONTEND_MESSAGING_SENDER_ID=123456789012
FRONTEND_APP_ID=1:123456789012:web:abcdefabcdefabcdef

# ── Alert Thresholds (overridable per device via Firebase) ────────────────────
TEMP_WARNING_C=35.0
TEMP_CRITICAL_C=45.0
HUMIDITY_WARNING_PCT=80.0
LIGHT_LOW_THRESHOLD=200

# ── AWS IoT Core ───────────────────────────────────────────────────────────────
# Found in: AWS Console → IoT Core → Settings → Endpoint
AWS_IOT_ENDPOINT=xxxxxxxxxxxxxx-ats.iot.us-east-1.amazonaws.com

# The Thing Name you created in AWS IoT Core (typically same as DEVICE_ID)
AWS_THING_NAME=esp32_node_01

# Set to true to enable AWS IoT MQTT alongside Firebase
AWS_ENABLED=false

# ── Biometric / Iris Configuration ────────────────────────────────────────────
# GPIO pin for the authentication button (short press = auth, long press = enroll mode)
AUTH_BUTTON_PIN=15

# Iris matching: L2 distance threshold — lower = stricter (0.20–0.35 recommended)
IRIS_MATCH_THRESHOLD=0.30

# Number of camera frames averaged per enrollment capture (more = more stable)
IRIS_ENROLL_FRAMES=5

# ── Anomaly Detection ─────────────────────────────────────────────────────────
# Composite anomaly score above this triggers an alert (0.0–1.0)
ANOMALY_SCORE_THRESHOLD=0.60

# Minimum ms between duplicate alerts of the same type
ALERT_COOLDOWN_MS=30000

# ── AWS Lambda / Bedrock Agent (cloud-side alert routing) ─────────────────────
# The Lambda function ARN that handles alerts from iot/{thing}/biometric/alert.
# Set up in AWS IoT Core → Act → Rules → Create rule → Lambda action.
ALERT_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:BiometricAlertAgent

# SNS Topic ARN for user notifications (used by Lambda → Bedrock Agent fallback)
ALERT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:BiometricAlerts
