firmware/.pio/
firmware/build/
*.hex
*.bin
*.elf
*.map

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
*.egg
pip-log.txt
.pytest_cache/

